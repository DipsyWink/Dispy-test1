    {
        "id": "2f5c24e83f1cd9a7",
        "type": "function",
        "z": "9c0332ec8fcd40fa",
        "name": "function 1",
        "func": "// 1. Recupera o ranking atual da memória\nlet ranking = global.get(\"ranking_acumulado\") || [];\n\n// 2. Se a mensagem veio do \"UI Event\" (carregamento da página)\n// ou se o Inject de limpeza foi acionado (limpar)\nif (msg.ui_event === \"connect\" || msg.topic === \"limpar\") {\n    if (msg.topic === \"limpar\") {\n        ranking = [];\n        global.set(\"ranking_acumulado\", []);\n    }\n    msg.payload = ranking;\n    return msg;\n}\n\n// 3. Processamento normal de novos pontos do Arduino (Wokwi)\nlet entrada;\ntry {\n    entrada = (typeof msg.payload === 'object') ? msg.payload : JSON.parse(msg.payload);\n} catch (e) { return null; }\n\nif (entrada && entrada.tag) {\n    ranking.push({\n        \"tag\": String(entrada.tag),\n        \"score\": parseInt(entrada.score)\n    });\n\n    ranking.sort((a, b) => b.score - a.score);\n    ranking = ranking.slice(0, 10); // <--- DEVE SER 10 AQUI\n    global.set(\"ranking_acumulado\", ranking);\n\n    msg.payload = ranking;\n    return msg;\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
