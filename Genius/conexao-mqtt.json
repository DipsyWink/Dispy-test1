        "order": 0,
        "width": 0,
        "height": 0,
        "format": "<style>\n    .ranking-box {\n        font-family: 'Segoe UI', sans-serif;\n        background-color: #ffffff;\n        border-radius: 8px;\n        border: 1px solid #ddd;\n        /* Garante que a tabela tenha espaço para os 10 itens */\n        min-height: 450px;\n        overflow-y: auto;\n    }\n\n    .ranking-table {\n        width: 100%;\n        border-collapse: collapse;\n    }\n\n    .ranking-table th {\n        background-color: #f8f9fa;\n        padding: 12px;\n        text-align: left;\n        position: sticky;\n        /* Mantém o cabeçalho no topo ao rolar */\n        top: 0;\n        border-bottom: 2px solid #dee2e6;\n    }\n\n    .ranking-table td {\n        padding: 10px 12px;\n        border-bottom: 1px solid #eee;\n    }\n\n    .ranking-row:nth-child(even) {\n        background-color: #fafafa;\n    }\n\n    .pos-col {\n        width: 40px;\n        font-weight: bold;\n        color: #666;\n    }\n\n    .score-col {\n        text-align: right;\n        font-weight: bold;\n        color: #1b5e20;\n    }\n</style>\n\n<div class=\"ranking-box\">\n    <table class=\"ranking-table\">\n        <thead>\n            <tr>\n                <th class=\"pos-col\">#</th>\n                <th>Jogador</th>\n                <th style=\"text-align: right;\">Pontos</th>\n            </tr>\n        </thead>\n        <tbody>\n            <tr class=\"ranking-row\" ng-repeat=\"item in msg.payload track by $index\">\n                <td class=\"pos-col\">{{$index + 1}}º</td>\n                <td style=\"text-transform: uppercase;\">{{item.tag}}</td>\n                <td class=\"score-col\">{{item.score}} pts</td>\n            </tr>\n        </tbody>\n    </table>\n</div>",
